pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'Java'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                 credentialsId: '5c66587e-cc6f-4c4e-afdc-9648cfe4d14f',
                 url: 'https://github.com/MalakBourrich/jenkins-java-project.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Package') {
            steps {
                bat 'mvn package'
            }
        }
    }
    post {

        success {
            echo "Build #${BUILD_NUMBER} réussi"
                // emailext to: 'team@example.com', subject: 'Build OK', body: '...'
        }
        failure {
            echo "Build #${BUILD_NUMBER} échoué"
        }
        always {
            cleanWs() // nettoyer le workspace après chaque build
        }
    }
    }
}